msgid "Siirry pääsisältöön"
msgstr "Gå till huvudinnehållet"

msgid "Avaa valikko"
msgstr "Öppna menyn"

msgid "Päänavigaatio"
msgstr "Huvudnavigation"

msgid "Kielivalinta"
msgstr "Språkval"

msgid "Sivusto"
msgstr "Webbplats"

msgid "Yhteystiedot"
msgstr "Kontaktuppgifter"

msgid "Seuraa meitä"
msgstr "Följ oss"

msgid "Tietosuojaseloste →"
msgstr "Dataskyddsbeskrivning →"

msgid "Kuntapolitiikka"
msgstr "Kommunalpolitik"

msgid "Vihreät vaikuttavat ympäri Uudenmaan — valtuustoissa, lautakunnissa ja arjen päätöksissä."
msgstr "De Gröna verkar i hela Nyland — i fullmäktige, nämnder och vardagliga beslut."

msgid "Kotikuntasi vihreät"
msgstr "De gröna i din hemkommun"

msgid "Yhdistyksen pj"
msgstr "Föreningens ordförande"

msgid "Valtuustoryhmän pj"
msgstr "Fullmäktigegruppens ordförande"

msgid "Yhdistyksen sivut →"
msgstr "Föreningens webbplats →"

msgid "Aiemmat vaalit"
msgstr "Tidigare val"

msgid "Vihreiden vaalimenestys Uudellamaalla — tulokset, valitut edustajat ja äänimäärät vaaleittain."
msgstr "De Grönas valframgångar i Nyland — resultat, valda representanter och röstantal per val."

msgid "Eduskuntavaalit"
msgstr "Riksdagsval"

msgid "Kuntavaalit"
msgstr "Kommunalval"

msgid "Aluevaalit"
msgstr "Välfärdsområdesval"

msgid "Europarlamenttivaalit"
msgstr "Europaparlamentsval"

msgid "EU-vaaleissa paikat jaetaan valtakunnallisesti."
msgstr "I EU-valen fördelas platserna nationellt."

msgid "Presidentinvaalit"
msgstr "Presidentval"

msgid "Vuosi"
msgstr "År"

msgid "Äänimäärä"
msgstr "Antal röster"

msgid "Kannatus"
msgstr "Stöd"

msgid "Kansanedustajia"
msgstr "Riksdagsledamöter"

msgid "Valtuutettuja"
msgstr "Fullmäktigeledamöter"

msgid "Aluevaltuutettuja"
msgstr "Välfärdsområdesledamöter"

msgid "Kierros"
msgstr "Omgång"

msgid "Ehdokas"
msgstr "Kandidat"

msgid "Hyvinvointialueet"
msgstr "Välfärdsområden"

msgid "Uusimaa jakautuu neljään hyvinvointialueeseen. Vihreät vaikuttavat jokaisella alueella. Lisäksi toimimme kunnissa, HUS:ssa ja erilaisissa alueellisissa luottamustehtävissä."
msgstr "Nyland är indelat i fyra välfärdsområden. De Gröna är aktiva i alla områden. Vi verkar också i kommunerna, HUS och i olika regionala förtroendeuppdrag."

msgid "Faktaa piiristä"
msgstr "Fakta om distriktet"

msgid "Tervetuloa — löydät täältä yhteystiedot, taustatietoa piiristä sekä ladattavan kuva- ja logomateriaalin."
msgstr "Välkommen — här hittar du kontaktuppgifter, bakgrundsinformation om distriktet samt nedladdningsbart bild- och logomaterial."

msgid "Puheenjohtaja"
msgstr "Ordförande"

msgid "Toiminnanjohtaja"
msgstr "Verksamhetsledare"

msgid "Jäsentä"
msgstr "Medlemmar"

msgid "Kuntaa"
msgstr "Kommuner"

msgid "Kansanedustajaa"
msgstr "Riksdagsledamöter"

msgid "Valtuutettua"
msgstr "Fullmäktigeledamöter"

msgid "Mediayhteyshenkilöt"
msgstr "Mediakontakter"

msgid "Uudenmaan Vihreiden tiedotteet"
msgstr "Nylands Grönas pressmeddelanden"

msgid "Logot & kuvamateriaali"
msgstr "Logotyper & bildmaterial"

msgid "Kuvapankki"
msgstr "Bildbank"

msgid "Kampanjointikuvat ja henkilökuvat ovat saatavilla Google Drivessä."
msgstr "Kampanjbilder och porträttfoton finns tillgängliga i Google Drive."

msgid "Viimeisimmät puolueen tiedotteet"
msgstr "Senaste pressmeddelanden från partiet"

msgid "Tilaa vihreiden uutiskirje"
msgstr "Prenumerera på de grönas nyhetsbrev"

msgid "Lue lisää →"
msgstr "Läs mer →"

msgid "Kaikki tapahtumat →"
msgstr "Alla evenemang →"

msgid "Uutisia, kannanottoja ja tietoa Uudenmaan Vihreiden toiminnasta."
msgstr "Nyheter, ställningstaganden och information om Nylands Grönas verksamhet."

msgid "Vaalit ovat demokratian sydän."
msgstr "Val är demokratins hjärta."

msgid "Uudenmaan Vihreät on Vihreiden piirijärjestö, joka toimii koko Uudenmaan vaalipiirin alueella."
msgstr "Nylands Gröna är Grönas distriktsorganisation som verkar inom hela Nylands valkrets."

msgid "Vihreät tarvitsee rohkeita ehdokkaita joka kunnasta. Sinulla on annettavaa — autamme sinut matkaan."
msgstr "De Gröna behöver modiga kandidater från varje kommun. Du har något att ge — vi hjälper dig på vägen."

msgid "Uudenmaan Vihreiden tavoitteet tulevissa vaaleissa."
msgstr "Nylands Grönas mål inför kommande val."

msgid "Yleiskokous on Uudenmaan Vihreiden ylin päättävä elin, joka kokoontuu kerran vuodessa."
msgstr "Allmänna mötet är Nylands Grönas högsta beslutande organ och samlas en gång om året."

msgid "EU:n yleisen tietosuoja-asetuksen mukaiset rekisteri- ja tietosuojaselosteet."
msgstr "Register- och dataskyddsbeskrivningar enligt EU:s allmänna dataskyddsförordning."

msgid "Piiritoimisto palvelee jäseniä, yhdistyksiä ja mediaa. Ota rohkeasti yhteyttä."
msgstr "Distriktskansliet betjänar medlemmar, föreningar och media. Ta gärna kontakt."

msgid "Piirihallitus vastaa Uudenmaan Vihreiden toiminnan johtamisesta yleiskokouksien välillä."
msgstr "Distriktsstyrelsen ansvarar för ledningen av Nylands Grönas verksamhet mellan allmänna möten."

msgid "Uudeltamaalta valitut Vihreiden kansanedustajat työskentelevät eduskunnassa Uudenmaan ja koko Suomen parhaaksi."
msgstr "De Grönas riksdagsledamöter valda från Nyland arbetar i riksdagen för Nylands och hela Finlands bästa."

msgid "Löydä oikea henkilö tai ota yhteyttä piiriin — olemme täällä sinua varten."
msgstr "Hitta rätt person eller kontakta distriktet — vi finns här för dig."

msgid "Uudenmaan tulevat vihreät tapahtumat."
msgstr "Kommande gröna evenemang i Nyland."

msgid "Uudenmaan Vihreiden tiedotteet, kannanotot ja puheenvuorot medialle."
msgstr "Nylands Grönas pressmeddelanden, ställningstaganden och anföranden för media."

msgid "Vihreä politiikka syntyy ihmisten yhteisestä tekemisestä. Löydä oma tapasi vaikuttaa."
msgstr "Grön politik uppstår ur människors gemensamma handlande. Hitta ditt eget sätt att påverka."

msgid "Paikallisyhdistykset ja kuntavaikuttaminen ympäri Uusimaata."
msgstr "Lokalföreningar och kommunalt påverkansarbete runt om i Nyland."
